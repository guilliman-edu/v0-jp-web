  {
    "apiVersion": "v1",
    "kind": "ActividadLectura",
    "metadata": {
      "name": "a1-s9-lectura-dia-ciudad"
    },
    "data": {
      "genero": "practica",
      "titulo": "町のいちにち",
      "modoFurigana": "templado",
      "furiganaList": [],
      "nombres_propios": [
        {
          "literal": "鈴木",
          "lectura": "すずき"
        }
      ],
      "texto": "きょうはいい天気です。鈴木さんはともだちと町に行きます。\n\nけさ、七時に起きました。朝ごはんを食べました。\n鈴木さんは毎日七時に起きます。\nときどき一人で朝ごはんを食べます。\n\n八時にうちを出ました。駅でともだちに会いました。\nいつも駅で会います。とても楽しいです。\n\n町で映画を見ました。とてもおもしろかったです。\n鈴木さんはよく映画を見ます。\nあまりテレビを見ません。\n\nお昼にレストランで食べました。\n鈴木さんはあまりお肉を食べません。魚を食べました。\n\n午後、買い物をしました。本とCDを買いました。\n鈴木さんはぜんぜんコーヒーを飲みません。\nいつもお茶を飲みます。\n\nこんばん、七時にうちに帰ります。\nあしたは試験があります。うちで勉強します。\n",
      "preguntas": [
        "鈴木さんはけさ、何時に起きましたか。",
        "鈴木さんはいつもどこでともだちに会いますか。",
        "鈴木さんはよく何を見ますか。",
        "鈴木さんはお昼に何を食べましたか。",
        "鈴木さんはコーヒーを飲みますか。",
        "あした、鈴木さんは何がありますか。"
      ],
      "vocabulario": [
        {
          "literal": "町",
          "lectura": "まち",
          "significado": "ciudad, pueblo"
        },
        {
          "literal": "出る",
          "lectura": "でる",
          "significado": "salir"
        },
        {
