{
  "audio_file": "a1-s9-lectura-dia-ciudad.wav",
  "sample_rate": 44100,
  "pause_ms": 500,
  "total_duration_ms": 91013,
  "sentences": [
    {
      "index": 0,
      "text": "町のいちにち",
      "start_ms": 0,
      "end_ms": 2396,
      "duration_ms": 2396
    },
    {
      "index": 1,
      "text": "きょうはいい天気です。",
      "start_ms": 2896,
      "end_ms": 5570,
      "duration_ms": 2674
    },
    {
      "index": 2,
      "text": "鈴木さんはともだちと町に行きます。",
      "start_ms": 6070,
      "end_ms": 10137,
      "duration_ms": 4067
    },
    {
      "index": 3,
      "text": "けさ、七時に起きました。",
      "start_ms": 10637,
      "end_ms": 13718,
      "duration_ms": 3081
    },
    {
      "index": 4,
      "text": "朝ごはんを食べました。",
      "start_ms": 14218,
      "end_ms": 17066,
      "duration_ms": 2848
    },
    {
      "index": 5,
      "text": "鈴木さんは毎日七時に起きます。",
      "start_ms": 17566,
      "end_ms": 22086,
      "duration_ms": 4520
    },
    {
      "index": 6,
      "text": "ときどき一人で朝ごはんを食べます。",
      "start_ms": 22586,
      "end_ms": 26932,
      "duration_ms": 4346
    },
    {
      "index": 7,
      "text": "八時にうちを出ました。",
      "start_ms": 27432,
      "end_ms": 30304,
      "duration_ms": 2872
    },
    {
      "index": 8,
      "text": "駅でともだちに会いました。",
      "start_ms": 30804,
      "end_ms": 33815,
      "duration_ms": 3011
    },
    {
      "index": 9,
      "text": "いつも駅で会います。",
      "start_ms": 34315,
      "end_ms": 37001,
      "duration_ms": 2686
    },
    {
      "index": 10,
      "text": "とても楽しいです。",
      "start_ms": 37501,
      "end_ms": 39931,
      "duration_ms": 2430
    },
    {
      "index": 11,
      "text": "町で映画を見ました。",
      "start_ms": 40431,
      "end_ms": 43407,
      "duration_ms": 2976
    },
    {
      "index": 12,
      "text": "とてもおもしろかったです。",
      "start_ms": 43907,
      "end_ms": 46860,
      "duration_ms": 2953
    },
    {
      "index": 13,
      "text": "鈴木さんはよく映画を見ます。",
      "start_ms": 47360,
      "end_ms": 51033,
      "duration_ms": 3673
    },
    {
      "index": 14,
      "text": "あまりテレビを見ません。",
      "start_ms": 51533,
      "end_ms": 54602,
      "duration_ms": 3069
    },
    {
      "index": 15,
      "text": "お昼にレストランで食べました。",
      "start_ms": 55102,
      "end_ms": 58415,
      "duration_ms": 3313
    },
    {
      "index": 16,
      "text": "鈴木さんはあまりお肉を食べません。",
      "start_ms": 58915,
      "end_ms": 63087,
      "duration_ms": 4172
    },
    {
      "index": 17,
      "text": "魚を食べました。",
      "start_ms": 63587,
      "end_ms": 66087,
      "duration_ms": 2500
    },
    {
      "index": 18,
      "text": "午後、買い物をしました。",
      "start_ms": 66587,
      "end_ms": 69343,
      "duration_ms": 2756
    },
    {
      "index": 19,
      "text": "本とCDを買いました。",
      "start_ms": 69843,
      "end_ms": 72262,
      "duration_ms": 2419
    },
    {
      "index": 20,
      "text": "鈴木さんはぜんぜんコーヒーを飲みません。",
      "start_ms": 72762,
      "end_ms": 77027,
      "duration_ms": 4265
    },
    {
      "index": 21,
      "text": "いつもお茶を飲みます。",
      "start_ms": 77527,
      "end_ms": 80271,
      "duration_ms": 2744
    },
    {
      "index": 22,
      "text": "こんばん、七時にうちに帰ります。",
      "start_ms": 80771,
      "end_ms": 84653,
      "duration_ms": 3882
    },
    {
      "index": 23,
      "text": "あしたは試験があります。",
      "start_ms": 85153,
      "end_ms": 87920,
      "duration_ms": 2767
    },
    {
      "index": 24,
      "text": "うちで勉強します。",
      "start_ms": 88420,
      "end_ms": 91013,
      "duration_ms": 2593
    }
  ]
}